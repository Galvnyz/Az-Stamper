  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "readinessCheck",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "functionAppName": {
            "value": "[parameters('functionAppName')]"
          },
          "resourceGroupName": {
            "value": "[parameters('resourceGroupName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "1711270150522235831"
            }
          },
          "parameters": {
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "Name of the function app to check."
              }
            },
            "resourceGroupName": {
              "type": "string",
              "metadata": {
                "description": "Resource group of the function app."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]"
            }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}-readiness-id', parameters('functionAppName'))]",
              "location": "[parameters('location')]"
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(resourceGroup().id, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName'))), 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName'))), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName')))]"
              ]
            },
            {
              "type": "Microsoft.Resources/deploymentScripts",
              "apiVersion": "2023-08-01",
              "name": "[format('{0}-readiness-check', parameters('functionAppName'))]",
              "location": "[parameters('location')]",
              "kind": "AzureCLI",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName'))))]": {}
                }
              },
              "properties": {
                "azCliVersion": "2.63.0",
                "retentionInterval": "PT1H",
                "timeout": "PT10M",
                "cleanupPreference": "OnSuccess",
                "scriptContent": "      echo \"Waiting for function app to register ResourceStamper...\"\n      for i in $(seq 1 30); do\n        funcs=$(az functionapp function list \\\n          --name $FUNCTION_APP_NAME \\\n          --resource-group $RESOURCE_GROUP_NAME \\\n          --query \"[?name=='ResourceStamper'].name\" -o tsv 2>/dev/null)\n        if [ \"$funcs\" = \"ResourceStamper\" ]; then\n          echo \"ResourceStamper function is ready (attempt $i)\"\n          exit 0\n        fi\n        echo \"Attempt $i/30: function not ready yet, waiting 20s...\"\n        sleep 20\n      done\n      echo \"ERROR: ResourceStamper function did not become ready within 10 minutes\"\n      exit 1\n    ",
                "environmentVariables": [
                  {
                    "name": "FUNCTION_APP_NAME",
                    "value": "[parameters('functionAppName')]"
                  },
                  {
                    "name": "RESOURCE_GROUP_NAME",
                    "value": "[parameters('resourceGroupName')]"
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName'))), 'acdd72a7-3385-48ef-bd42-f606fba81ae7'))]",
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName')))]"
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "az-stamper-enrollment",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "systemTopicName": {
            "value": "[parameters('systemTopicName')]"
          },
          "eventSubscriptionName": {
            "value": "[parameters('eventSubscriptionName')]"
          },
          "functionAppId": {
            "value": "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Web/sites', parameters('functionAppName'))]"
          },
          "subscriptionId": {
            "value": "[subscription().subscriptionId]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "2096511882392230420"
            }
          },
          "parameters": {
            "systemTopicName": {
              "type": "string"
            },
            "eventSubscriptionName": {
              "type": "string"
            },
            "functionAppId": {
              "type": "string"
            },
            "subscriptionId": {
              "type": "string"
            },
            "location": {
              "type": "string",
              "defaultValue": "global"
            }
          },
          "resources": [
            {
              "type": "Microsoft.EventGrid/systemTopics",
              "apiVersion": "2022-06-15",
              "name": "[parameters('systemTopicName')]",
              "location": "[parameters('location')]",
              "properties": {
                "source": "[format('/subscriptions/{0}', parameters('subscriptionId'))]",
                "topicType": "Microsoft.Resources.Subscriptions"
              }
            },
            {
              "type": "Microsoft.EventGrid/systemTopics/eventSubscriptions",
              "apiVersion": "2022-06-15",
              "name": "[format('{0}/{1}', parameters('systemTopicName'), parameters('eventSubscriptionName'))]",
              "properties": {
                "destination": {
                  "endpointType": "AzureFunction",
                  "properties": {
                    "resourceId": "[format('{0}/functions/ResourceStamper', parameters('functionAppId'))]"
                  }
                },
                "filter": {
                  "includedEventTypes": [
                    "Microsoft.Resources.ResourceWriteSuccess"
                  ],
                  "advancedFilters": [
                    {
                      "operatorType": "StringNotContains",
                      "key": "data.operationName",
                      "values": [
                        "Microsoft.Resources/deployments",
                        "Microsoft.Resources/tags"
                      ]
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.EventGrid/systemTopics', parameters('systemTopicName'))]"
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'readinessCheck')]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
