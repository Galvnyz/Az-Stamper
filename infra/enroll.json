{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "9998097337827983947"
    }
  },
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "rg-az-stamper",
      "metadata": {
        "description": "Name of the resource group containing the Az-Stamper hub."
      }
    },
    "functionAppName": {
      "type": "string",
      "defaultValue": "func-az-stamper",
      "metadata": {
        "description": "Name of the Az-Stamper function app."
      }
    },
    "systemTopicName": {
      "type": "string",
      "defaultValue": "evgt-az-stamper",
      "metadata": {
        "description": "Name for the Event Grid system topic"
      }
    },
    "eventSubscriptionName": {
      "type": "string",
      "defaultValue": "evgs-az-stamper",
      "metadata": {
        "description": "Name for the Event Grid event subscription"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "readinessCheck",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "functionAppName": {
            "value": "[parameters('functionAppName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "6090549278719109117"
            }
          },
          "parameters": {
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "Name of the function app to check."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]"
            }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}-readiness-id', parameters('functionAppName'))]",
              "location": "[parameters('location')]"
            },
            {
              "type": "Microsoft.Resources/deploymentScripts",
              "apiVersion": "2023-08-01",
              "name": "[format('{0}-readiness-check', parameters('functionAppName'))]",
              "location": "[parameters('location')]",
              "kind": "AzureCLI",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName'))))]": {}
                }
              },
              "properties": {
                "azCliVersion": "2.63.0",
                "retentionInterval": "PT1H",
                "timeout": "PT15M",
                "cleanupPreference": "OnSuccess",
                "scriptContent": "      echo \"Waiting for function app to finish loading from package...\"\n      for i in $(seq 1 40); do\n        status=$(curl -s -o /dev/null -w \"%{http_code}\" \"https://${FUNCTION_APP_NAME}.azurewebsites.net/\" --max-time 10 2>/dev/null)\n        if [ \"$status\" = \"200\" ] || [ \"$status\" = \"401\" ] || [ \"$status\" = \"404\" ]; then\n          echo \"Function host is responding (HTTP $status, attempt $i)\"\n          echo \"Waiting 30s for functions to finish registering...\"\n          sleep 30\n          echo \"Ready\"\n          exit 0\n        fi\n        echo \"Attempt $i/40: HTTP $status (not ready), waiting 20s...\"\n        sleep 20\n      done\n      echo \"ERROR: Function app did not become ready within 15 minutes\"\n      exit 1\n    ",
                "environmentVariables": [
                  {
                    "name": "FUNCTION_APP_NAME",
                    "value": "[parameters('functionAppName')]"
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-readiness-id', parameters('functionAppName')))]"
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "az-stamper-enrollment",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "systemTopicName": {
            "value": "[parameters('systemTopicName')]"
          },
          "eventSubscriptionName": {
            "value": "[parameters('eventSubscriptionName')]"
          },
          "functionAppId": {
            "value": "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Web/sites', parameters('functionAppName'))]"
          },
          "subscriptionId": {
            "value": "[subscription().subscriptionId]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "2096511882392230420"
            }
          },
          "parameters": {
            "systemTopicName": {
              "type": "string"
            },
            "eventSubscriptionName": {
              "type": "string"
            },
            "functionAppId": {
              "type": "string"
            },
            "subscriptionId": {
              "type": "string"
            },
            "location": {
              "type": "string",
              "defaultValue": "global"
            }
          },
          "resources": [
            {
              "type": "Microsoft.EventGrid/systemTopics",
              "apiVersion": "2022-06-15",
              "name": "[parameters('systemTopicName')]",
              "location": "[parameters('location')]",
              "properties": {
                "source": "[format('/subscriptions/{0}', parameters('subscriptionId'))]",
                "topicType": "Microsoft.Resources.Subscriptions"
              }
            },
            {
              "type": "Microsoft.EventGrid/systemTopics/eventSubscriptions",
              "apiVersion": "2022-06-15",
              "name": "[format('{0}/{1}', parameters('systemTopicName'), parameters('eventSubscriptionName'))]",
              "properties": {
                "destination": {
                  "endpointType": "AzureFunction",
                  "properties": {
                    "resourceId": "[format('{0}/functions/ResourceStamper', parameters('functionAppId'))]"
                  }
                },
                "filter": {
                  "includedEventTypes": [
                    "Microsoft.Resources.ResourceWriteSuccess"
                  ],
                  "advancedFilters": [
                    {
                      "operatorType": "StringNotContains",
                      "key": "data.operationName",
                      "values": [
                        "Microsoft.Resources/deployments",
                        "Microsoft.Resources/tags"
                      ]
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.EventGrid/systemTopics', parameters('systemTopicName'))]"
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'readinessCheck')]"
      ]
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "enrollmentRbac",
      "location": "[deployment().location]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "principalId": {
            "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Web/sites', parameters('functionAppName')), '2023-12-01', 'full').identity.principalId]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "252838764718187273"
            }
          },
          "parameters": {
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Principal ID of the function app managed identity."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(subscription().id, parameters('principalId'), 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal"
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(subscription().id, parameters('principalId'), '4a9ae827-6dc8-4573-8ac7-8239d42aa03f')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4a9ae827-6dc8-4573-8ac7-8239d42aa03f')]",
                "principalId": "[parameters('principalId')]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      }
    }
  ]
}